{
  "name": "@deck-forge/core",
  "version": "0.1.0",
  "type": "module",
  "repository": "https://github.com/deck-forge/deck-forge.git",
  "files": ["dist", "!dist/**/__tests__/**", "!dist/**/*.test.*", "!dist/tsconfig.tsbuildinfo"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#/*": "./dist/*"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1038.0",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^3.12.0"
  }
}
