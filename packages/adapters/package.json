{
  "name": "@deck-forge/adapters",
  "version": "0.2.1",
  "type": "module",
  "repository": "https://github.com/salty-vanilla/deck-forge.git",
  "files": ["dist", "!dist/**/__tests__/**", "!dist/**/*.test.*", "!dist/tsconfig.tsbuildinfo"],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./strands": {
      "types": "./dist/strands/index.d.ts",
      "default": "./dist/strands/index.js"
    }
  },
  "imports": {
    "#src/*": "./dist/*"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@deck-forge/tools": "workspace:*",
    "@strands-agents/sdk": "^1.0.0-rc.5",
    "zod": "^4.1.12"
  }
}
