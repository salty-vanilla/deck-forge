{
  "name": "@deck-forge/adapters",
  "version": "0.1.0",
  "type": "module",
  "repository": "https://github.com/deck-forge/deck-forge.git",
  "files": ["dist", "!dist/**/__tests__/**", "!dist/**/*.test.*", "!dist/tsconfig.tsbuildinfo"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./strands": {
      "types": "./dist/strands/index.d.ts",
      "default": "./dist/strands/index.js"
    }
  },
  "imports": {
    "#/*": "./dist/*"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@deck-forge/tools": "workspace:*",
    "@strands-agents/sdk": "^1.0.0-rc.5",
    "zod": "^4.1.12"
  }
}
